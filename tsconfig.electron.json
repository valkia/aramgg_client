{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "electron/**/*.ts",
    "electron/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron",
    "build",
    "**/*.spec.ts"
  ]
}
