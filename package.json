{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder",
    "start": "electron .",
    "lint": "eslint src --ext .js,.vue",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test:screenshots": "node electron/test-screenshot-analysis.js"
  },
  "build": {
    "productName": "client",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "xxx/icon.ico"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.0.1",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.6.2",
    "cheerio": "^1.1.2",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^9.0.0",
    "element-plus": "^2.3.8",
    "es6-promise-pool": "^2.5.0",
    "fs-extra": "^11.3.3",
    "lodash-es": "^4.17.22",
    "nanoid": "^3.3.7",
    "reka-ui": "^2.8.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "vue": "^3.4.21",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^5.0.2",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "39.2.7",
    "electron-builder": "^24.1.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^10.3.0",
    "lucide-vue-next": "^0.563.0",
    "postcss": "^8.5.6",
    "radix-vue": "^1.9.17",
    "shadcn-vue": "^2.4.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.4.5",
    "vue-tsc": "^1.8.27"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {
      "no-console": "off"
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
