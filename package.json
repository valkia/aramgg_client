{
  "name": "aramgg_client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "node scripts/pack-electron.mjs",
    "start": "electron .",
    "lint": "eslint src --ext .js,.vue",
    "type-check": "vue-tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "type-check:watch": "vue-tsc -p tsconfig.renderer.json --noEmit --watch",
    "test:screenshots": "node tests/electron/test-screenshot-analysis.js"
  },
  "build": {
    "productName": "aramgg_client",
    "directories": {
      "output": "build"
    },
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "chi_sim.traineddata",
        "to": "data/chi_sim.traineddata"
      }
    ],
    "win": {
      "icon": "public/icon.ico",
      "artifactName": "aramgg_client Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer/installer.nsh",
      "perMachine": false,
      "language": "2052",
      "installerLanguages": [
        "zh_CN"
      ],
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "aramgg_client"
    }
  },
  "dependencies": {
    "axios": "^1.16.1",
    "electron-store": "^11.0.2",
    "fs-extra": "^11.3.5",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "autoprefixer": "^10.5.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "39.2.7",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "lucide-vue-next": "^1.0.0",
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11",
    "postcss": "^8.5.14",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.7",
    "shadcn-vue": "^2.7.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vue-tsc": "^3.2.9"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
