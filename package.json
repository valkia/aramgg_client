{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder",
    "start": "electron .",
    "lint": "eslint src --ext .js,.vue"
  },
  "build": {
    "productName": "client",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/data",
        "to": "data",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "xxx/icon.ico"
    }
  },
  "dependencies": {
    "@electron/remote": "^2.0.1",
    "axios": "^1.6.2",
    "cheerio": "^1.1.2",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^9.0.0",
    "element-plus": "^2.3.8",
    "es6-promise-pool": "^2.5.0",
    "fs-extra": "^11.3.3",
    "lodash-es": "^4.17.22",
    "nanoid": "^3.3.7",
    "screenshot-desktop": "^1.15.3",
    "vue": "^3.4.21",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.2",
    "autoprefixer": "^10.4.23",
    "electron": "39.2.7",
    "electron-builder": "^24.1.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^10.3.0",
    "postcss": "^8.5.6"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {
      "no-console": "off"
    },
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "requireConfigFile": false,
      "babelOptions": {
        "plugins": [
          [
            "component",
            {
              "libraryName": "element-plus",
              "styleLibraryName": "theme-chalk"
            }
          ]
        ]
      }
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
